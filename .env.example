# ── Strava (developers.strava.com → your app) ───────────────────────
# Server-only secrets. NEVER expose these to the browser.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=          # owner's long-lived refresh token (one-time OAuth)
STRAVA_WEBHOOK_VERIFY_TOKEN=   # any random string; echoed back on webhook handshake

# ── Database (Neon Postgres via Vercel marketplace) ─────────────────
DATABASE_URL=                  # postgres://... (Neon pooled connection string)

# ── Misc ────────────────────────────────────────────────────────────
# Protects the cron/sync endpoint from public calls. Any random string.
SYNC_SECRET=
